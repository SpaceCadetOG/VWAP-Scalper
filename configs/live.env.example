VENUES_ENABLED=hyperliquid,aster,lighter,coinbase
ROUTER_MODE=latency_spread_hybrid
ROUTER_MULTI_VENUE_ENABLE=true
ROUTER_MAX_VENUES_PER_SIGNAL=3
ROUTER_GLOBAL_RISK_PER_SIGNAL_USD=30
ROUTER_VENUE_RISK_SPLIT_MODE=score_weighted
ROUTER_REQUIRE_ISOLATED=true
GLOBAL_MAX_DAILY_LOSS_PCT=1.5
GLOBAL_MAX_OPEN_RISK_R=3.0
ORDER_DEFAULT_MAX_ENTRY_DELAY_MS=1500
ORDER_DEFAULT_NO_FOLLOW_THROUGH_MS=120000
ORDER_DEFAULT_MAX_HOLD_MS=180000
ADAPTER_RECONNECT_BACKOFF_MS=250,500,1000,2000,5000

# Perps WS endpoints (WS-first)
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_ACCOUNT_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_SIGNER_ADDRESS=
HYPERLIQUID_API_WALLET_PRIVATE_KEY=
HYPERLIQUID_CHAIN_ID=42161
ASTER_WS_URL=wss://fstream.asterdex.com
ASTER_ACCOUNT_WS_URL=wss://fstream.asterdex.com/ws
ASTER_USER=
ASTER_SIGNER=
ASTER_SIGNER_ADDRESS=
ASTER_PRIVATE_KEY=
ASTER_SIGNER_PRIVATE_KEY=
ASTER_CHAIN_ID=1666
# Optional legacy fallback keys:
ASTER_API_KEY=
ASTER_API_SECRET=
LIGHTER_WS_URL=wss://mainnet.zklighter.elliot.ai/stream?readonly=true
LIGHTER_ACCOUNT_WS_URL=wss://mainnet.zklighter.elliot.ai/stream?readonly=true
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai
LIGHTER_ACCOUNT_INDEX=
LIGHTER_L1_ADDRESS=
LIGHTER_CHAIN_ID=304
LIGHTER_API_KEY_INDEX=
LIGHTER_API_KEY=
LIGHTER_API_SECRET=
# Use the private key generated in Lighter API key creation flow.
# If omitted, code falls back to LIGHTER_API_SECRET.
LIGHTER_API_PRIVATE_KEY=
# Strict no-cross guard (required for live order paths):
LIGHTER_MARGIN_MODE=isolated
LIGHTER_ISOLATED_CONFIRMED=false

# Coinbase (spot-only)
COINBASE_SPOT_ONLY=true
COINBASE_BASE_URL=https://api.exchange.coinbase.com
# Auth for spot balance/trading (next step):
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_PASSPHRASE=
